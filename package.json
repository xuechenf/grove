{
  "name": "grove",
  "version": "0.1.0",
  "description": "Local-first VM management web app with SSH, SFTP, terminal sessions, and Kimi-assisted operations.",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "author": "xuechenf",
  "repository": {
    "type": "git",
    "url": "https://github.com/xuechenf/grove.git"
  },
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c cyan,magenta \"npm:server:dev\" \"npm:dev:ui\"",
    "dev:ui": "vite --host 127.0.0.1 --port 5187 --strictPort",
    "server:dev": "tsx watch server/index.ts",
    "server:start": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "build:ui": "vite build",
    "build:electron": "node electron/build.mjs",
    "build:app": "npm run build:ui && npm run build:electron",
    "make-icon": "node electron/make-icon.mjs",
    "electron:dev": "npm run build:electron && concurrently -k -n vite,backend,electron -c magenta,cyan,yellow \"npm:dev:ui\" \"npm:server:dev\" \"cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5187 electron dist-electron/main.cjs\"",
    "dist": "npm run build:app && electron-builder",
    "dist:win": "npm run build:app && electron-builder --win",
    "dist:mac": "npm run build:app && electron-builder --mac",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@openuidev/react-lang": "^0.2.6",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ssh2": "^1.17.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
